    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "@types/node": "^22.13.0"
  }
}
